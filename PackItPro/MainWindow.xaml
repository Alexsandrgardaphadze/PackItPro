<!-- MainWindow.xaml -->
<Window x:Class="PackItPro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:PackItPro.Views"
        xmlns:vm="clr-namespace:PackItPro.ViewModels"
        mc:Ignorable="d"
        Title="PackItPro - Secure Package Builder"
        Height="650" Width="1050"
        Background="{DynamicResource AppBackgroundColor}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinWidth="900" MinHeight="600"
        Loaded="Window_Loaded"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        RenderOptions.BitmapScalingMode="NearestNeighbor">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Menu Bar -->
            <RowDefinition Height="*"/>
            <!-- Main Content -->
            <RowDefinition Height="Auto"/>
            <!-- Status Panel -->
        </Grid.RowDefinitions>

        <!-- ══ MENU BAR ════════════════════════════════════════════════════════
             DockPanel:
               LEFT  — the four Menu items (File / Settings / Tools / Help)
               RIGHT — a compact status strip (file count · VT badge · version)
             The strip is purely informational and doesn't need commands.
        -->
        <Border Grid.Row="0"
                Background="{DynamicResource AppPanelColor}"
                CornerRadius="8"
                Margin="0,0,0,12"
                Padding="4,0"
                BorderBrush="{DynamicResource AppBorderColor}"
                BorderThickness="1">

            <DockPanel LastChildFill="False">

                <!-- ── Left: navigation menu ────────────────────────────── -->
                <Menu DockPanel.Dock="Left"
                      Background="Transparent"
                      Padding="0,4,0,4"
                      VerticalAlignment="Center">

                    <MenuItem Header="File" Style="{StaticResource MenuItemStyle}">
                        <MenuItem Header="Add Files..."           Command="{Binding BrowseFilesCommand}"         Style="{StaticResource SubMenuItemStyle}"/>
                        <MenuItem Header="Clear All Files"        Command="{Binding ClearAllFilesCommand}"       Style="{StaticResource SubMenuItemStyle}"/>
                        <Separator Background="{DynamicResource AppBorderColor}"/>
                        <MenuItem Header="Export Logs..."         Command="{Binding ExportLogsCommand}"          Style="{StaticResource SubMenuItemStyle}"/>
                        <Separator Background="{DynamicResource AppBorderColor}"/>
                        <MenuItem Header="Exit"                   Command="{Binding ExitCommand}"                Style="{StaticResource SubMenuItemStyle}"/>
                    </MenuItem>

                    <MenuItem Header="Settings" Style="{StaticResource MenuItemStyle}">
                        <MenuItem Header="Output Location..."         Command="{Binding SetOutputLocationCommand}"   Style="{StaticResource SubMenuItemStyle}"/>
                        <MenuItem Header="VirusTotal API Key..."      Command="{Binding SetVirusApiKeyCommand}"      Style="{StaticResource SubMenuItemStyle}"/>
                        <MenuItem Header="Delete VirusTotal API Key"  Command="{Binding DeleteVirusApiKeyCommand}"   Style="{StaticResource SubMenuItemStyle}"/>
                        <MenuItem Header="PackItPro Settings..."      Command="{Binding PackItProSettingsCommand}"   Style="{StaticResource SubMenuItemStyle}"/>
                    </MenuItem>

                    <MenuItem Header="Tools" Style="{StaticResource MenuItemStyle}">
                        <MenuItem Header="Test Package..."   Command="{Binding TestPackageCommand}"   Style="{StaticResource SubMenuItemStyle}"/>
                        <MenuItem Header="View Cache..."     Command="{Binding ViewCacheCommand}"     Style="{StaticResource SubMenuItemStyle}"/>
                        <MenuItem Header="Clear Cache"       Command="{Binding ClearCacheCommand}"    Style="{StaticResource SubMenuItemStyle}"/>
                        <Separator Background="{DynamicResource AppBorderColor}"/>
                        <MenuItem Header="Export List..."    Command="{Binding ExportListCommand}"    Style="{StaticResource SubMenuItemStyle}"/>
                    </MenuItem>

                    <MenuItem Header="Help" Style="{StaticResource MenuItemStyle}">
                        <MenuItem Header="Toggle Theme"        Command="{Binding ToggleThemeCommand}"   Style="{StaticResource SubMenuItemStyle}"/>
                        <Separator Background="{DynamicResource AppBorderColor}"/>
                        <MenuItem Header="Documentation"      Command="{Binding DocumentationCommand}"  Style="{StaticResource SubMenuItemStyle}"/>
                        <MenuItem Header="GitHub Repository"  Command="{Binding GitHubCommand}"         Style="{StaticResource SubMenuItemStyle}"/>
                        <MenuItem Header="Report Issue"       Command="{Binding ReportIssueCommand}"    Style="{StaticResource SubMenuItemStyle}"/>
                        <Separator Background="{DynamicResource AppBorderColor}"/>
                        <MenuItem Header="Check for Updates"  Command="{Binding CheckUpdatesCommand}"   Style="{StaticResource SubMenuItemStyle}"/>
                        <Separator Background="{DynamicResource AppBorderColor}"/>
                        <MenuItem Header="About PackItPro"    Command="{Binding AboutCommand}"          Style="{StaticResource SubMenuItemStyle}"/>
                    </MenuItem>
                </Menu>

                <!-- ── Right: version label + theme toggle ────────────────────── -->
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0">

                    <!-- Thin divider -->
                    <Border Width="1" Background="{DynamicResource AppDividerColor}"
                            Margin="0,6,8,6" VerticalAlignment="Stretch"/>

                    <!-- Theme Toggle Button — modern pill switch -->
                    <Button Command="{Binding ToggleThemeCommand}"
                            Width="58" Height="28"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0"
                            ToolTip="Toggle Light / Dark theme"
                            Cursor="Hand"
                            FocusVisualStyle="{x:Null}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background"      Value="{DynamicResource AppCardColor}"/>
                                <Setter Property="BorderBrush"     Value="{DynamicResource AppBorderColor}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="pill"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="14">
                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            Margin="6,0">
                                                    <TextBlock Text="🌙" FontSize="12"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,4,0"/>
                                                    <Border Width="1"
                                                            Background="{DynamicResource AppBorderColor}"
                                                            Margin="0,3"/>
                                                    <TextBlock Text="☀️" FontSize="12"
                                                               VerticalAlignment="Center"
                                                               Margin="4,0,0,0"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="pill" Property="Background"
                                                            Value="{DynamicResource AppHoverOverlayColor}"/>
                                                    <Setter TargetName="pill" Property="BorderBrush"
                                                            Value="{DynamicResource AppPrimaryColor}"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="pill" Property="Opacity" Value="0.75"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Another divider -->
                    <Border Width="1" Background="{DynamicResource AppDividerColor}"
                            Margin="0,6,8,6" VerticalAlignment="Stretch"/>

                    <!-- Version label -->
                    <TextBlock Text="{Binding AppVersion}"
                               FontFamily="Consolas" FontSize="11"
                               Foreground="{DynamicResource AppTextTertiaryColor}"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0"/>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- MAIN CONTENT AREA -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <views:FileListPanel Grid.Column="0" DataContext="{Binding FileList}"/>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <views:PackSettingsPanel DataContext="{Binding Settings}" Margin="0,0,0,10"/>
                    <views:SummaryPanel DataContext="{Binding Summary}"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- STATUS PANEL -->
        <views:StatusPanel Grid.Row="2" Margin="0,0,0,8" DataContext="{Binding Status}"/>
    </Grid>
</Window>
