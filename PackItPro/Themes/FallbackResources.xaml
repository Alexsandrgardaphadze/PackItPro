<!-- Themes/FallbackResources.xaml
     OPTIMIZATION: All brushes originally here were duplicates of keys already defined
     in Colors.xaml, and ExpanderHeaderStyle was already defined in Styles.xaml.
     WPF resource lookup walks every merged dictionary on every StaticResource lookup.
     Duplicate keys in a later dictionary shadow the earlier one, which is correct
     behaviour — but it also means WPF still scans both files before resolving.
     Keeping only genuinely missing fallbacks here cuts the lookup chain.

     This file must still exist in the MergedDictionaries list in App.xaml because
     removing it from the list would shift other dictionary indices. It is intentionally
     left nearly empty rather than removed entirely.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- All fallback entries removed — primary definitions in Colors.xaml and
         Styles.xaml cover all keys. Add genuinely missing fallbacks here only. -->
</ResourceDictionary>
