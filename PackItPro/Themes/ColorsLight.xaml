<!-- Themes/ColorsLight.xaml -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Background
         Three-level depth system:
           AppBackgroundColor  = cool blue-gray canvas (#eef2f7)  — the page base
           AppPanelColor       = white (#ffffff)                   — elevated panels
           AppCardColor        = soft blue-tinted white (#f5f8fc)  — cards inside panels
         This gives clear visual hierarchy without harsh contrast.
    ──────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="AppBackgroundColor"  Color="#eef2f7"/>
    <SolidColorBrush x:Key="AppPanelColor"       Color="#ffffff"/>
    <SolidColorBrush x:Key="AppPanelHoverColor"  Color="#f0f4f8"/>
    <SolidColorBrush x:Key="AppCardColor"        Color="#f5f8fc"/>

    <!-- ── Accent (same indigo hue, darkened for light bg contrast) ── -->
    <SolidColorBrush x:Key="AppPrimaryColor"        Color="#4f46e5"/>
    <SolidColorBrush x:Key="AppPrimaryHoverColor"   Color="#4338ca"/>
    <SolidColorBrush x:Key="AppPrimaryPressedColor" Color="#3730a3"/>
    <SolidColorBrush x:Key="AppSecondaryColor"      Color="#7c3aed"/>

    <!-- ── Status ───────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="AppStatusCleanColor"   Color="#059669"/>
    <SolidColorBrush x:Key="AppStatusWarningColor" Color="#d97706"/>
    <SolidColorBrush x:Key="AppStatusErrorColor"   Color="#dc2626"/>
    <SolidColorBrush x:Key="AppStatusPendingColor" Color="#2563eb"/>
    <SolidColorBrush x:Key="AppStatusInfoColor"    Color="#0891b2"/>

    <!-- ── Text — dark enough to read on both white and blue-gray bg ── -->
    <SolidColorBrush x:Key="AppTextColor"           Color="#0f172a"/>
    <SolidColorBrush x:Key="AppTextSecondaryColor"  Color="#1e293b"/>
    <SolidColorBrush x:Key="AppTextTertiaryColor"   Color="#475569"/>
    <SolidColorBrush x:Key="AppTextQuaternaryColor" Color="#64748b"/>
    <SolidColorBrush x:Key="AppTextDisabledColor"   Color="#94a3b8"/>

    <!-- ── Borders — blue-gray tint so they're visible on both surfaces -->
    <SolidColorBrush x:Key="AppBorderColor"      Color="#d1d9e6"/>
    <SolidColorBrush x:Key="AppBorderLightColor" Color="#bbc8db"/>
    <SolidColorBrush x:Key="AppDividerColor"     Color="#e4eaf3"/>

    <!-- ── Interactive ──────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="AppDropAreaHoverColor"  Color="#6366f1"/>
    <SolidColorBrush x:Key="AppHoverOverlayColor"   Color="#dce6f5"/>

    <!-- ── Glass ────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="AppGlassBackground" Color="#CCffffff"/>
    <SolidColorBrush x:Key="AppGlassBorder"     Color="#33000000"/>

    <!-- ── Gradients ────────────────────────────────────────────────── -->
    <LinearGradientBrush x:Key="AppPrimaryGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#4f46e5" Offset="0"/>
        <GradientStop Color="#7c3aed" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AppSuccessGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#059669" Offset="0"/>
        <GradientStop Color="#047857" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AppDangerGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#dc2626" Offset="0"/>
        <GradientStop Color="#b91c1c" Offset="1"/>
    </LinearGradientBrush>

    <!-- ── Shadow Effects (subtle for light mode) ───────────────────── -->
    <DropShadowEffect x:Key="AppCardShadow"
                      xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
                      po:Freeze="True"
                      Color="#8ca3c0"
                      Opacity="0.15"
                      BlurRadius="12"
                      ShadowDepth="2"
                      Direction="270"/>

    <DropShadowEffect x:Key="AppButtonShadow"
                      xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
                      po:Freeze="True"
                      Color="#8ca3c0"
                      Opacity="0.12"
                      BlurRadius="6"
                      ShadowDepth="1"
                      Direction="270"/>

    <DropShadowEffect x:Key="AppGlowEffect"
                      xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
                      po:Freeze="True"
                      Color="#4f46e5"
                      Opacity="0.25"
                      BlurRadius="12"
                      ShadowDepth="0"/>

    <!-- ── Semantic warning/error subtle backgrounds ────────────────── -->
    <SolidColorBrush x:Key="AppWarningSubtleBg"     Color="#fefce8"/>
    <SolidColorBrush x:Key="AppWarningSubtleBorder"  Color="#fde68a"/>
    <SolidColorBrush x:Key="AppErrorSubtleBg"        Color="#fef2f2"/>
    <SolidColorBrush x:Key="AppErrorSubtleBorder"    Color="#fecaca"/>

</ResourceDictionary>
