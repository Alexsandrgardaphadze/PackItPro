<Window x:Class="PackItPro.Views.UpdateAvailableWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update Available"
        Height="480" Width="480"
        MinHeight="420" MinWidth="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource AppBackgroundColor}"
        ShowInTaskbar="False">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- header -->
            <RowDefinition Height="Auto"/>
            <!-- version row -->
            <RowDefinition Height="*"/>
            <!-- release notes -->
            <RowDefinition Height="Auto"/>
            <!-- progress area -->
            <RowDefinition Height="Auto"/>
            <!-- buttons -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
            <TextBlock Text="&#x2B06;" FontSize="20" Margin="0,0,10,0"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource AppStatusCleanColor}"/>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Update Available"
                           FontSize="16" FontWeight="SemiBold"
                           FontFamily="Segoe UI"
                           Foreground="{StaticResource AppTextColor}"/>
                <TextBlock x:Name="SubtitleText"
                           FontSize="12" FontFamily="Segoe UI"
                           Foreground="{StaticResource AppTextTertiaryColor}"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </StackPanel>

        <!-- Version pill row -->
        <Border Grid.Row="1"
                Background="{StaticResource AppCardColor}"
                BorderBrush="{StaticResource AppBorderColor}"
                BorderThickness="1" CornerRadius="8"
                Padding="14,10" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="CURRENT"
                               FontSize="9" FontWeight="SemiBold"
                               FontFamily="Segoe UI"
                               Foreground="{StaticResource AppTextTertiaryColor}"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="CurrentVersionText"
                               FontSize="15" FontWeight="SemiBold"
                               FontFamily="Consolas"
                               Foreground="{StaticResource AppTextSecondaryColor}"
                               HorizontalAlignment="Center"
                               Margin="0,3,0,0"/>
                </StackPanel>

                <TextBlock Grid.Column="1" Text="&#x2192;"
                           FontSize="18"
                           Foreground="{StaticResource AppStatusCleanColor}"
                           VerticalAlignment="Center"
                           Margin="16,0"/>

                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="NEW"
                               FontSize="9" FontWeight="SemiBold"
                               FontFamily="Segoe UI"
                               Foreground="{StaticResource AppTextTertiaryColor}"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="NewVersionText"
                               FontSize="15" FontWeight="SemiBold"
                               FontFamily="Consolas"
                               Foreground="{StaticResource AppStatusCleanColor}"
                               HorizontalAlignment="Center"
                               Margin="0,3,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Release notes -->
        <Border Grid.Row="2"
                Background="{StaticResource AppCardColor}"
                BorderBrush="{StaticResource AppBorderColor}"
                BorderThickness="1" CornerRadius="8"
                Padding="14,10" Margin="0,0,0,12">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="RELEASE NOTES"
                           FontSize="9" FontWeight="SemiBold"
                           FontFamily="Segoe UI"
                           Foreground="{StaticResource AppTextTertiaryColor}"
                           Margin="0,0,0,6"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <TextBlock x:Name="ReleaseNotesText"
                               FontSize="12" FontFamily="Segoe UI"
                               Foreground="{StaticResource AppTextSecondaryColor}"
                               TextWrapping="Wrap"
                               LineHeight="18"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Progress area (collapsed until download starts) -->
        <StackPanel Grid.Row="3" x:Name="ProgressArea"
                    Margin="0,0,0,12"
                    Visibility="Collapsed">
            <DockPanel Margin="0,0,0,5">
                <TextBlock x:Name="ProgressLabel"
                           Text="Downloading..."
                           FontSize="12" FontFamily="Segoe UI"
                           Foreground="{StaticResource AppTextSecondaryColor}"
                           DockPanel.Dock="Left"/>
                <TextBlock x:Name="ProgressBytes"
                           FontSize="12" FontFamily="Consolas"
                           Foreground="{StaticResource AppTextTertiaryColor}"
                           HorizontalAlignment="Right"/>
            </DockPanel>
            <ProgressBar x:Name="DownloadProgress"
                         Height="6" Minimum="0" Maximum="100"
                         Background="{StaticResource AppCardColor}"
                         BorderThickness="0"
                         Foreground="{StaticResource AppStatusCleanColor}"/>
        </StackPanel>

        <!-- Buttons -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Open in browser link -->
            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center">
                <Hyperlink x:Name="OpenBrowserLink" Click="OpenBrowser_Click"
                           Foreground="{StaticResource AppTextTertiaryColor}">
                    <Run Text="View on GitHub"/>
                </Hyperlink>
            </TextBlock>

            <Button Grid.Column="1" x:Name="LaterButton"
                    Content="Later" Width="80" Height="34"
                    IsCancel="True"
                    Click="Later_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="{StaticResource AppPanelHoverColor}"/>
                        <Setter Property="Foreground" Value="{StaticResource AppTextColor}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource AppBorderColor}"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="FontFamily" Value="Segoe UI"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="7">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AppBorderColor}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Grid.Column="3" x:Name="InstallButton"
                    Content="Download &amp; Install" Width="150" Height="34"
                    IsDefault="True"
                    Click="Install_Click"
                    Style="{StaticResource Win11Button}"/>
        </Grid>
    </Grid>
</Window>
