<!-- PackItPro/Views/EasterEggOverlay.xaml
     Triggered by the Konami code (↑↑↓↓←→←→BA).
     Hardcoded Miku-teal colors so it looks correct in both themes.
     The overlay is IsHitTestVisible=False so clicks pass through.
-->
<Window x:Class="PackItPro.Views.EasterEggOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        Width="460" Height="380"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        Focusable="False"
        IsHitTestVisible="False">

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <!-- Fade the whole overlay in -->
                    <DoubleAnimation Storyboard.TargetName="EggRoot"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.35"/>

                    <!-- Card slides up from below -->
                    <DoubleAnimation Storyboard.TargetName="CardTranslate"
                                     Storyboard.TargetProperty="Y"
                                     From="40" To="0" Duration="0:0:0.4">
                        <DoubleAnimation.EasingFunction>
                            <BackEase EasingMode="EaseOut" Amplitude="0.4"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>

                    <!-- Rotate the emoji ring (targets the RotateTransform named EmojiSpin) -->
                    <DoubleAnimation Storyboard.TargetName="EmojiSpin"
                                     Storyboard.TargetProperty="Angle"
                                     From="0" To="360"
                                     Duration="0:0:4"
                                     RepeatBehavior="Forever"/>

                    <!-- Pulse the teal glow opacity -->
                    <DoubleAnimation Storyboard.TargetName="CardGlow"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.25" To="0.75"
                                     Duration="0:0:0.9"
                                     AutoReverse="True"
                                     RepeatBehavior="Forever"/>

                    <!-- Fade out after hold period -->
                    <DoubleAnimation Storyboard.TargetName="EggRoot"
                                     Storyboard.TargetProperty="Opacity"
                                     From="1" To="0"
                                     Duration="0:0:0.6"
                                     BeginTime="0:0:4.0"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid x:Name="EggRoot" Opacity="0">

        <!-- Floating sparkle particles around the card (decorative, non-interactive) -->
        <Canvas IsHitTestVisible="False">
            <Ellipse Canvas.Left="30"  Canvas.Top="60"  Width="6"  Height="6"  Fill="#4039d4c8"/>
            <Ellipse Canvas.Left="400" Canvas.Top="70"  Width="8"  Height="8"  Fill="#3039d4c8"/>
            <Ellipse Canvas.Left="60"  Canvas.Top="300" Width="5"  Height="5"  Fill="#4039d4c8"/>
            <Ellipse Canvas.Left="370" Canvas.Top="290" Width="7"  Height="7"  Fill="#3039d4c8"/>
            <TextBlock Canvas.Left="50"  Canvas.Top="130" Text="✦" FontSize="11" Foreground="#3039d4c8"/>
            <TextBlock Canvas.Left="380" Canvas.Top="150" Text="✦" FontSize="11" Foreground="#3039d4c8"/>
            <TextBlock Canvas.Left="210" Canvas.Top="20"  Text="✦" FontSize="14" Foreground="#4039d4c8"/>
        </Canvas>

        <!-- Main card -->
        <Border CornerRadius="20" Margin="20"
                Background="#EE0d1117"
                BorderBrush="#5039d4c8"
                BorderThickness="1.5">
            <Border.RenderTransform>
                <TranslateTransform x:Name="CardTranslate" Y="40"/>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect x:Name="CardGlow"
                                  Color="#39d4c8"
                                  Opacity="0.3"
                                  BlurRadius="36"
                                  ShadowDepth="0"/>
            </Border.Effect>

            <StackPanel Margin="28,22" HorizontalAlignment="Center">

                <!-- Rotating emoji ring — single Grid with one RenderTransform -->
                <Grid Width="80" Height="80"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,4"
                      RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <RotateTransform x:Name="EmojiSpin" Angle="0"/>
                    </Grid.RenderTransform>
                    <TextBlock Text="✨" FontSize="14"
                               HorizontalAlignment="Left"  VerticalAlignment="Top"
                               Margin="2,2,0,0"/>
                    <TextBlock Text="🎵" FontSize="12"
                               HorizontalAlignment="Right" VerticalAlignment="Top"
                               Margin="0,2,2,0"/>
                    <TextBlock Text="💙" FontSize="12"
                               HorizontalAlignment="Left"  VerticalAlignment="Bottom"
                               Margin="2,0,0,2"/>
                    <TextBlock Text="⭐" FontSize="12"
                               HorizontalAlignment="Right" VerticalAlignment="Bottom"
                               Margin="0,0,2,2"/>
                </Grid>

                <!-- Miku text -->
                <TextBlock Text="ミク"
                           FontSize="44"
                           FontFamily="Segoe UI Emoji, Yu Gothic, MS Gothic"
                           HorizontalAlignment="Center"
                           Foreground="#39d4c8"/>

                <TextBlock Text="(ﾉ◕ヮ◕)ﾉ*:･ﾟ✧"
                           FontSize="19"
                           FontFamily="Segoe UI Emoji"
                           HorizontalAlignment="Center"
                           Foreground="#5be0d8"
                           Margin="0,4,0,12"/>

                <!-- Title -->
                <TextBlock Text="You found the secret! ✨"
                           FontSize="16" FontWeight="SemiBold"
                           FontFamily="Segoe UI"
                           Foreground="#ffffff"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <!-- Random quote from code-behind -->
                <TextBlock x:Name="QuoteText"
                           FontSize="12" FontFamily="Segoe UI"
                           Foreground="#8eb8b6"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="360"
                           Margin="0,0,0,10"/>

                <!-- Japanese subtitle -->
                <TextBlock Text="✨ 初音ミクはあなたを応援しています ✨"
                           FontSize="11"
                           FontFamily="Segoe UI Emoji, Yu Gothic"
                           Foreground="#2f7572"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,14"/>

                <!-- Teal divider -->
                <Border Height="1" Background="#1e39d4c8"
                        CornerRadius="1" Margin="30,0,30,10"/>

                <!-- Konami reminder -->
                <TextBlock Text="↑ ↑ ↓ ↓ ← → ← → B A"
                           FontSize="10" FontFamily="Consolas"
                           Foreground="#256663"
                           HorizontalAlignment="Center"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>
