<Window x:Class="PackItPro.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About PackItPro"
        Height="Auto" Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource AppBackgroundColor}"
        ShowInTaskbar="False">

    <Grid Margin="12">
        <Border Background="{StaticResource AppPanelColor}"
                BorderBrush="{StaticResource AppBorderColor}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="28,24">
            <StackPanel>

                <!-- Logo + name -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,20">
                    <Border Width="64" Height="64"
                            CornerRadius="16"
                            Background="{StaticResource AppPrimaryColor}"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,14">
                        <TextBlock Text="📦"
                                   FontSize="32"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="PackItPro"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource AppTextColor}"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="VersionText"
                               Text="v0.6.6"
                               FontSize="12"
                               Foreground="{StaticResource AppTextTertiaryColor}"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"
                               Margin="0,3,0,0"/>
                </StackPanel>

                <!-- Divider -->
                <Border Height="1" Background="{StaticResource AppDividerColor}" Margin="0,0,0,18"/>

                <!-- Description -->
                <TextBlock Text="A secure package builder for bundling multiple applications into a single self-extracting installer."
                           FontSize="13"
                           Foreground="{StaticResource AppTextSecondaryColor}"
                           FontFamily="Segoe UI"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           LineHeight="20"
                           Margin="0,0,0,18"/>

                <!-- Info rows -->
                <Border Background="{StaticResource AppCardColor}"
                        CornerRadius="8" Padding="14,12"
                        BorderBrush="{StaticResource AppBorderColor}"
                        BorderThickness="1"
                        Margin="0,0,0,18">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Author"
                                       FontSize="12" Foreground="{StaticResource AppTextTertiaryColor}"
                                       FontFamily="Segoe UI"/>
                            <TextBlock Grid.Column="1" Text="ZenQuant"
                                       FontSize="12" Foreground="{StaticResource AppTextColor}"
                                       FontFamily="Segoe UI" FontWeight="SemiBold"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="License"
                                       FontSize="12" Foreground="{StaticResource AppTextTertiaryColor}"
                                       FontFamily="Segoe UI"/>
                            <TextBlock Grid.Column="1" Text="© 2026 — All rights reserved"
                                       FontSize="12" Foreground="{StaticResource AppTextColor}"
                                       FontFamily="Segoe UI"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Platform"
                                       FontSize="12" Foreground="{StaticResource AppTextTertiaryColor}"
                                       FontFamily="Segoe UI"/>
                            <TextBlock Grid.Column="1" Text=".NET 8 · WPF · Windows"
                                       FontSize="12" Foreground="{StaticResource AppTextColor}"
                                       FontFamily="Segoe UI"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- GitHub button -->
                <Button x:Name="GitHubButton"
                        Height="36"
                        Click="GitHubButton_Click"
                        Cursor="Hand"
                        Margin="0,0,0,10">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="{StaticResource AppPanelHoverColor}"/>
                            <Setter Property="Foreground" Value="{StaticResource AppTextColor}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource AppBorderColor}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="FontFamily" Value="Segoe UI"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="7">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource AppBorderColor}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⭐" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="View on GitHub" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Close button -->
                <Button Content="Close"
                        Height="36"
                        IsDefault="True"
                        IsCancel="True"
                        Click="CloseButton_Click"
                        Style="{StaticResource Win11Button}"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>
