<Window x:Class="PackItPro.Views.CacheViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VirusTotal Scan Cache"
        Height="340" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource AppBackgroundColor}"
        ShowInTaskbar="False">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource AppPanelColor}"
                BorderBrush="{StaticResource AppBorderColor}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="22,18">
            <StackPanel>

                <!-- Header -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                    <TextBlock Text="🛡️" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="VirusTotal Scan Cache"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource AppTextColor}"
                               FontFamily="Segoe UI" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Stats grid -->
                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Entries -->
                    <Border Grid.Column="0" Background="{StaticResource AppCardColor}"
                            CornerRadius="8" Padding="12"
                            BorderBrush="{StaticResource AppBorderColor}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="ENTRIES" FontSize="9" FontWeight="SemiBold"
                                       Foreground="{StaticResource AppTextTertiaryColor}"
                                       FontFamily="Segoe UI" Margin="0,0,0,4"/>
                            <TextBlock x:Name="EntryCountText" Text="—"
                                       FontSize="22" FontWeight="Bold"
                                       FontFamily="Consolas"
                                       Foreground="{StaticResource AppTextColor}"/>
                            <TextBlock Text="cached files" FontSize="10"
                                       Foreground="{StaticResource AppTextTertiaryColor}"
                                       FontFamily="Segoe UI"/>
                        </StackPanel>
                    </Border>

                    <!-- Cache size -->
                    <Border Grid.Column="2" Background="{StaticResource AppCardColor}"
                            CornerRadius="8" Padding="12"
                            BorderBrush="{StaticResource AppBorderColor}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="SIZE" FontSize="9" FontWeight="SemiBold"
                                       Foreground="{StaticResource AppTextTertiaryColor}"
                                       FontFamily="Segoe UI" Margin="0,0,0,4"/>
                            <TextBlock x:Name="CacheSizeText" Text="—"
                                       FontSize="22" FontWeight="Bold"
                                       FontFamily="Consolas"
                                       Foreground="{StaticResource AppTextColor}"/>
                            <TextBlock Text="on disk" FontSize="10"
                                       Foreground="{StaticResource AppTextTertiaryColor}"
                                       FontFamily="Segoe UI"/>
                        </StackPanel>
                    </Border>

                    <!-- Last modified -->
                    <Border Grid.Column="4" Background="{StaticResource AppCardColor}"
                            CornerRadius="8" Padding="12"
                            BorderBrush="{StaticResource AppBorderColor}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="UPDATED" FontSize="9" FontWeight="SemiBold"
                                       Foreground="{StaticResource AppTextTertiaryColor}"
                                       FontFamily="Segoe UI" Margin="0,0,0,4"/>
                            <TextBlock x:Name="LastModText" Text="—"
                                       FontSize="13" FontWeight="SemiBold"
                                       FontFamily="Segoe UI"
                                       Foreground="{StaticResource AppTextColor}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- File path -->
                <TextBlock Text="Cache location" FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource AppTextTertiaryColor}"
                           FontFamily="Segoe UI" Margin="0,0,0,4"/>
                <Border Background="{StaticResource AppCardColor}"
                        CornerRadius="6" Padding="10,8"
                        BorderBrush="{StaticResource AppBorderColor}" BorderThickness="1">
                    <TextBlock x:Name="CachePathText"
                               FontFamily="Consolas" FontSize="11"
                               Foreground="{StaticResource AppTextSecondaryColor}"
                               TextWrapping="Wrap"/>
                </Border>

            </StackPanel>
        </Border>

        <!-- Footer buttons -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="Open in Notepad"
                    Height="34" Padding="16,0"
                    Margin="0,0,10,0"
                    FontSize="13"
                    Click="OpenNotepad_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="{StaticResource AppPanelHoverColor}"/>
                        <Setter Property="Foreground" Value="{StaticResource AppTextColor}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource AppBorderColor}"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="FontFamily" Value="Segoe UI"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="7">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AppBorderColor}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="Close"
                    Width="90" Height="34"
                    IsDefault="True"
                    Click="CloseButton_Click"
                    Style="{StaticResource Win11Button}"/>
        </StackPanel>
    </Grid>
</Window>
