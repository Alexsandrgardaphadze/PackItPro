<Window x:Class="PackItPro.Views.VirusApiKeyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VirusTotal API Key"
        Height="220"
        Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource AppBackgroundColor}">

    <Grid Margin="12">

        <Border Background="{StaticResource AppPanelColor}"
                BorderBrush="{StaticResource AppBorderColor}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="18">

            <StackPanel>

                <TextBlock Text="Enter your VirusTotal API Key"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource AppTextColor}"
                           Margin="0,0,0,12"/>

                <TextBox x:Name="ApiKeyBox"
                         Height="36"
                         Padding="10,4"
                         VerticalContentAlignment="Center"
                         Margin="0,0,0,14"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">

                    <Button Content="Cancel"
                            Width="80"
                            Margin="0,0,8,0"
                            Click="Cancel_Click"/>

                    <Button Content="Save"
                            Width="80"
                            Click="Save_Click"/>

                </StackPanel>

            </StackPanel>

        </Border>

    </Grid>
</Window>