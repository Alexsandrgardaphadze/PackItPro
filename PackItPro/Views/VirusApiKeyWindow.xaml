<Window x:Class="PackItPro.Views.VirusApiKeyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VirusTotal API Key"
        Height="220"
        Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource AppBackgroundColor}">

    <Grid Margin="12">

        <Border Background="{StaticResource AppPanelColor}"
                BorderBrush="{StaticResource AppBorderColor}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="18">

            <StackPanel>

                <TextBlock Text="Enter your VirusTotal API Key"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource AppTextColor}"
                           Margin="0,0,0,12"/>

                <TextBox x:Name="ApiKeyBox"
                         Height="36"
                         Padding="10,4"
                         VerticalContentAlignment="Center"
                         Margin="0,0,0,14"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">

                    <Button Content="Cancel"
                            Width="80"
                            Margin="0,0,8,0"
                            IsCancel="True"
                            Click="Cancel_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{StaticResource AppPanelHoverColor}"/>
                                <Setter Property="Foreground" Value="{StaticResource AppTextColor}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource AppBorderColor}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="FontFamily" Value="Segoe UI"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Height" Value="34"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="7">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource AppBorderColor}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="Save"
                            Width="80"
                            Height="34"
                            IsDefault="True"
                            Click="Save_Click"
                            Style="{StaticResource Win11Button}"/>

                </StackPanel>

            </StackPanel>

        </Border>

    </Grid>
</Window>