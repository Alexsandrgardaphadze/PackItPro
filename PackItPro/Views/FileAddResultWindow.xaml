<Window x:Class="PackItPro.Views.FileAddResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Files Added"
        Height="Auto" Width="440"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource AppBackgroundColor}"
        ShowInTaskbar="False">

    <Grid Margin="12">
        <Border Background="{StaticResource AppPanelColor}"
                BorderBrush="{StaticResource AppBorderColor}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="22,18">
            <StackPanel>

                <!-- Header -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Border x:Name="IconBorder"
                            Width="38" Height="38" CornerRadius="19"
                            Background="#3322c55e"
                            Margin="0,0,12,0" VerticalAlignment="Center">
                        <TextBlock x:Name="IconText" Text="✓"
                                   FontSize="18"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="TitleText"
                               Text="Files Added"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource AppTextColor}"
                               FontFamily="Segoe UI"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Success count -->
                <Border x:Name="SuccessBox"
                        Background="{StaticResource AppCardColor}"
                        CornerRadius="8" Padding="14,10"
                        BorderBrush="{StaticResource AppBorderColor}"
                        BorderThickness="1"
                        Margin="0,0,0,10"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Added successfully"
                                   FontSize="13" Foreground="{StaticResource AppTextSecondaryColor}"
                                   FontFamily="Segoe UI" VerticalAlignment="Center"/>
                        <TextBlock x:Name="SuccessCountText"
                                   Grid.Column="1"
                                   Text="0 file(s)"
                                   FontSize="14" FontWeight="Bold"
                                   FontFamily="Consolas"
                                   Foreground="{StaticResource AppStatusCleanColor}"/>
                    </Grid>
                </Border>

                <!-- Skipped section -->
                <Border x:Name="SkippedBox"
                        Background="{StaticResource AppCardColor}"
                        CornerRadius="8" Padding="14,10"
                        BorderBrush="{StaticResource AppBorderColor}"
                        BorderThickness="1"
                        Margin="0,0,0,10"
                        Visibility="Collapsed">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Skipped"
                                       FontSize="13" Foreground="{StaticResource AppTextSecondaryColor}"
                                       FontFamily="Segoe UI" VerticalAlignment="Center"/>
                            <TextBlock x:Name="SkippedCountText"
                                       Grid.Column="1"
                                       Text="0 file(s)"
                                       FontSize="14" FontWeight="Bold"
                                       FontFamily="Consolas"
                                       Foreground="{StaticResource AppStatusErrorColor}"/>
                        </Grid>
                        <Border Height="1" Background="{StaticResource AppDividerColor}" Margin="0,0,0,8"/>
                        <ItemsControl x:Name="SkipReasonsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               FontSize="11"
                                               FontFamily="Segoe UI"
                                               Foreground="{StaticResource AppTextTertiaryColor}"
                                               TextWrapping="Wrap"
                                               Margin="0,1"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock x:Name="MoreSkippedText"
                                   FontSize="11"
                                   Foreground="{StaticResource AppTextTertiaryColor}"
                                   FontFamily="Segoe UI"
                                   Margin="0,4,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <!-- OK -->
                <Button Content="OK"
                        Width="90" Height="34"
                        HorizontalAlignment="Right"
                        IsDefault="True"
                        IsCancel="True"
                        Click="OkButton_Click"
                        Style="{StaticResource Win11Button}"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>
