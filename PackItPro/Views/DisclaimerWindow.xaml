<Window x:Class="PackItPro.Views.DisclaimerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PackItPro Safety Notice"
        Height="560" Width="500"
        MinHeight="500" MinWidth="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource AppBackgroundColor}"
        ShowInTaskbar="False">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- header -->
            <RowDefinition Height="*"/>
            <!-- clauses -->
            <RowDefinition Height="Auto"/>
            <!-- "do not show again" -->
            <RowDefinition Height="Auto"/>
            <!-- buttons -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Packaging Disclaimer"
                       FontSize="17" FontWeight="SemiBold"
                       FontFamily="Segoe UI"
                       Foreground="{StaticResource AppTextColor}"/>
            <TextBlock Text="Please read before proceeding."
                       FontSize="12" FontFamily="Segoe UI"
                       Foreground="{StaticResource AppTextTertiaryColor}"
                       Margin="0,4,0,0"/>
        </StackPanel>
        <!-- File summary — populated in code-behind -->
        <Border x:Name="FileSummaryBorder"
                Grid.Row="0"
                Background="{StaticResource AppCardColor}"
                BorderBrush="{StaticResource AppBorderColor}"
                BorderThickness="1" CornerRadius="8"
                Padding="14,10" Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="FILES" FontSize="9" FontWeight="SemiBold"
                               FontFamily="Segoe UI" HorizontalAlignment="Center"
                               Foreground="{StaticResource AppTextTertiaryColor}" Margin="0,0,0,3"/>
                    <TextBlock x:Name="SummaryFilesText" FontSize="15" FontWeight="SemiBold"
                               FontFamily="Consolas" HorizontalAlignment="Center"
                               Foreground="{StaticResource AppTextColor}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="SCANNED" FontSize="9" FontWeight="SemiBold"
                               FontFamily="Segoe UI" HorizontalAlignment="Center"
                               Foreground="{StaticResource AppTextTertiaryColor}" Margin="0,0,0,3"/>
                    <TextBlock x:Name="SummaryScannedText" FontSize="15" FontWeight="SemiBold"
                               FontFamily="Consolas" HorizontalAlignment="Center"
                               Foreground="{StaticResource AppTextColor}"/>
                </StackPanel>
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="UNSCANNED" FontSize="9" FontWeight="SemiBold"
                               FontFamily="Segoe UI" HorizontalAlignment="Center"
                               Foreground="{StaticResource AppTextTertiaryColor}" Margin="0,0,0,3"/>
                    <TextBlock x:Name="SummaryUnscannedText" FontSize="15" FontWeight="SemiBold"
                               FontFamily="Consolas" HorizontalAlignment="Center"
                               Foreground="{StaticResource AppStatusErrorColor}"/>
                </StackPanel>
                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                    <TextBlock Text="INFECTED" FontSize="9" FontWeight="SemiBold"
                               FontFamily="Segoe UI" HorizontalAlignment="Center"
                               Foreground="{StaticResource AppTextTertiaryColor}" Margin="0,0,0,3"/>
                    <TextBlock x:Name="SummaryInfectedText" FontSize="15" FontWeight="SemiBold"
                               FontFamily="Consolas" HorizontalAlignment="Center"
                               Foreground="{StaticResource AppStatusErrorColor}"/>
                </StackPanel>
                <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                    <TextBlock Text="TRUSTED" FontSize="9" FontWeight="SemiBold"
                               FontFamily="Segoe UI" HorizontalAlignment="Center"
                               Foreground="{StaticResource AppTextTertiaryColor}" Margin="0,0,0,3"/>
                    <TextBlock x:Name="SummaryTrustedText" FontSize="15" FontWeight="SemiBold"
                               FontFamily="Consolas" HorizontalAlignment="Center"
                               Foreground="{StaticResource AppTextColor}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Clauses -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Margin="0,0,0,14">
            <StackPanel>

                <!-- 1. Responsibility -->
                <Border Background="{StaticResource AppCardColor}"
                        BorderBrush="{StaticResource AppBorderColor}"
                        BorderThickness="1" CornerRadius="8"
                        Padding="14,12" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="YOUR RESPONSIBILITY"
                                   FontSize="9" FontWeight="SemiBold"
                                   FontFamily="Segoe UI"
                                   Foreground="{StaticResource AppTextTertiaryColor}"
                                   Margin="0,0,0,6"/>
                        <TextBlock FontSize="12" FontFamily="Segoe UI"
                                   Foreground="{StaticResource AppTextSecondaryColor}"
                                   TextWrapping="Wrap" LineHeight="18">
                            You are solely responsible for the content of any package you create.
                            PackItPro bundles files as-is and does not inspect, modify, or validate
                            their behaviour beyond hash verification and optional VirusTotal scanning.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- 2. Legal / distribution -->
                <Border Background="{StaticResource AppCardColor}"
                        BorderBrush="{StaticResource AppBorderColor}"
                        BorderThickness="1" CornerRadius="8"
                        Padding="14,12" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="LEGAL USE ONLY"
                                   FontSize="9" FontWeight="SemiBold"
                                   FontFamily="Segoe UI"
                                   Foreground="{StaticResource AppTextTertiaryColor}"
                                   Margin="0,0,0,6"/>
                        <TextBlock FontSize="12" FontFamily="Segoe UI"
                                   Foreground="{StaticResource AppTextSecondaryColor}"
                                   TextWrapping="Wrap" LineHeight="18">
                            You confirm that you have the legal right to distribute every file
                            included in this package. Distributing malware, unlicensed software,
                            or files you do not own or have permission to redistribute may violate
                            applicable laws. ZenQuant and PackItPro accept no liability for misuse.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- 3. VirusTotal limitation -->
                <Border Background="{StaticResource AppCardColor}"
                        BorderBrush="{StaticResource AppBorderColor}"
                        BorderThickness="1" CornerRadius="8"
                        Padding="14,12" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="SCANNING LIMITATIONS"
                                   FontSize="9" FontWeight="SemiBold"
                                   FontFamily="Segoe UI"
                                   Foreground="{StaticResource AppTextTertiaryColor}"
                                   Margin="0,0,0,6"/>
                        <TextBlock FontSize="12" FontFamily="Segoe UI"
                                   Foreground="{StaticResource AppTextSecondaryColor}"
                                   TextWrapping="Wrap" LineHeight="18">
                            VirusTotal scanning reduces risk but does not guarantee safety.
                            A clean result does not mean a file is safe — only that it was not
                            detected by the engines queried at this time. New threats may not yet
                            be in vendor databases.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- 4. Unscanned files warning — shown only when relevant -->
                <Border x:Name="UnscannedWarningBorder"
                        Background="#2a2010"
                        BorderBrush="#6b5a20"
                        BorderThickness="1" CornerRadius="8"
                        Padding="14,12" Margin="0,0,0,8"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="&#x26A0;  UNSCANNED FILES"
                                   FontSize="9" FontWeight="SemiBold"
                                   FontFamily="Segoe UI"
                                   Foreground="#d4a017"
                                   Margin="0,0,0,6"/>
                        <TextBlock FontSize="12" FontFamily="Segoe UI"
                                   Foreground="{StaticResource AppTextSecondaryColor}"
                                   TextWrapping="Wrap" LineHeight="18">
                            One or more files in your list have not been scanned.
                            Consider running a VirusTotal scan before packaging.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- 5. Admin privilege warning — shown only when relevant -->
                <Border x:Name="AdminWarningBorder"
                        Background="#2a1a10"
                        BorderBrush="#6b3a20"
                        BorderThickness="1" CornerRadius="8"
                        Padding="14,12" Margin="0,0,0,8"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="&#x26A0;  ADMINISTRATOR PRIVILEGES"
                                   FontSize="9" FontWeight="SemiBold"
                                   FontFamily="Segoe UI"
                                   Foreground="#e07840"
                                   Margin="0,0,0,6"/>
                        <TextBlock FontSize="12" FontFamily="Segoe UI"
                                   Foreground="{StaticResource AppTextSecondaryColor}"
                                   TextWrapping="Wrap" LineHeight="18">
                            This package is configured to request administrator privileges on
                            the target machine. Only proceed if elevated permissions are genuinely
                            required by the bundled installers.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- 6. Infected files — shown only when relevant -->
                <Border x:Name="InfectedWarningBorder"
                        Background="#2a1010"
                        BorderBrush="#6b2020"
                        BorderThickness="1" CornerRadius="8"
                        Padding="14,12" Margin="0,0,0,8"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="&#x26A0;  INFECTED FILES DETECTED"
                                   FontSize="9" FontWeight="SemiBold"
                                   FontFamily="Segoe UI"
                                   Foreground="{StaticResource AppStatusErrorColor}"
                                   Margin="0,0,0,6"/>
                        <TextBlock FontSize="12" FontFamily="Segoe UI"
                                   Foreground="{StaticResource AppTextSecondaryColor}"
                                   TextWrapping="Wrap" LineHeight="18">
                            One or more files in your list were flagged by VirusTotal.
                            Packaging infected files is strongly discouraged. Remove or
                            review them before proceeding.
                        </TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Do not show again -->
        <CheckBox Grid.Row="2"
                  x:Name="DoNotShowAgainBox"
                  Content="I understand — do not show this again"
                  FontFamily="Segoe UI" FontSize="12"
                  Foreground="{StaticResource AppTextSecondaryColor}"
                  IsChecked="False"
                  Checked="DoNotShowAgain_Checked"
                  Unchecked="DoNotShowAgain_Unchecked"
                  Margin="0,0,0,16"/>

        <!-- Buttons -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1" x:Name="CancelButton"
                    Content="Cancel" Width="90" Height="34"
                    IsCancel="True"
                    Click="Cancel_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="{StaticResource AppPanelHoverColor}"/>
                        <Setter Property="Foreground" Value="{StaticResource AppTextColor}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource AppBorderColor}"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="FontFamily" Value="Segoe UI"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="7">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AppBorderColor}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Grid.Column="3" x:Name="AcceptButton"
                    Content="Accept &amp; Continue" Width="150" Height="34"
                    IsEnabled="False"
                    IsDefault="True"
                    Click="Accept_Click"
                    Style="{StaticResource Win11Button}"/>
        </Grid>
    </Grid>
</Window>
