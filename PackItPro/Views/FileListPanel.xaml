<!-- Views/FileListPanel.xaml -->
<UserControl x:Class="PackItPro.Views.FileListPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <Storyboard x:Key="PulseAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="EmptyStateIcon"
                             Storyboard.TargetProperty="Opacity"
                             From="0.4" To="1.0"
                             Duration="0:0:2"
                             AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Style x:Key="DeleteButtonStyle" TargetType="Button">
            <Setter Property="Width"           Value="24"/>
            <Setter Property="Height"          Value="24"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource AppTextTertiaryColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="ToolTip"         Value="Remove"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <Viewbox Width="16" Height="16"
                                     HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Canvas Width="20" Height="20">
                                    <Path Data="{StaticResource Icon.Delete}"
                                          Fill="{TemplateBinding Foreground}"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AppStatusErrorColor}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AppStatusErrorColor}"/>
                                <Setter Property="Opacity"    Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom Args TextBox: invisible at rest, border on hover/focus -->
        <Style x:Key="NotesTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background"             Value="Transparent"/>
            <Setter Property="BorderThickness"        Value="0"/>
            <Setter Property="Foreground"             Value="{DynamicResource AppTextSecondaryColor}"/>
            <Setter Property="FontFamily"             Value="Segoe UI"/>
            <Setter Property="FontSize"               Value="11"/>
            <Setter Property="Padding"                Value="4,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush"             Value="{DynamicResource AppPrimaryColor}"/>
            <Setter Property="SelectionBrush"         Value="{DynamicResource AppPrimaryColor}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Padding="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush"
                                        Value="{DynamicResource AppBorderColor}"/>
                                <Setter TargetName="border" Property="Background"
                                        Value="{DynamicResource AppPanelHoverColor}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush"
                                        Value="{DynamicResource AppPrimaryColor}"/>
                                <Setter TargetName="border" Property="Background"
                                        Value="{DynamicResource AppPanelHoverColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border x:Name="MainBorder"
            Margin="0,0,10,0"
            BorderBrush="{DynamicResource AppBorderColor}"
            BorderThickness="1" CornerRadius="12"
            Background="{DynamicResource AppPanelColor}"
            AllowDrop="True"
            Drop="UserControl_Drop"
            DragEnter="UserControl_DragEnter"
            DragLeave="UserControl_DragLeave">

        <Grid>
            <Border CornerRadius="12" Opacity="0.03">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="White" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- EMPTY STATE -->
            <Grid Name="EmptyDropState"
                  Visibility="{Binding HasFiles, Converter={StaticResource InverseBoolToVisibility}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="30">
                    <Border x:Name="EmptyStateIcon" Width="90" Height="90"
                            Background="{DynamicResource AppPanelHoverColor}" CornerRadius="45"
                            HorizontalAlignment="Center" Margin="0,0,0,20">
                        <TextBlock Text="📦" FontSize="48"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppPrimaryColor}"
                                   FontFamily="Segoe UI Emoji"/>
                    </Border>

                    <TextBlock Text="Drop Your Files Here" FontSize="20" FontWeight="SemiBold"
                               Foreground="{DynamicResource AppTextColor}"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               FontFamily="Segoe UI" Margin="0,0,0,6"/>

                    <TextBlock FontSize="13" Foreground="{DynamicResource AppTextTertiaryColor}"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               LineHeight="20" FontFamily="Segoe UI" Margin="0,0,0,18">
                        <Run Text="Drag and drop files or folders here"/>
                        <LineBreak/>
                        <Run FontSize="11">
                            <Run.Text>
                                <MultiBinding StringFormat="Maximum {0} files per package">
                                    <Binding RelativeSource="{RelativeSource AncestorType=Window}"
                                             Path="DataContext.Settings.SettingsModel.MaxFilesInList"/>
                                </MultiBinding>
                            </Run.Text>
                        </Run>
                    </TextBlock>

                    <Button Content="Browse Files"
                            Style="{StaticResource Win11Button}"
                            Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.BrowseFilesCommand}"
                            Height="40" Padding="24,0" FontSize="14" FontWeight="SemiBold" Cursor="Hand"/>
                </StackPanel>
            </Grid>

            <!-- FILE LIST
                 ItemContainerStyle = FileRowSlideInStyle (defined in Controls.xaml)
                 This gives each new row a 180ms fade + 8px slide-in.
                 VirtualizingPanel.IsVirtualizing is kept True for performance —
                 the slide-in animation fires on the ListViewItem.Loaded event
                 which virtualisation still raises when a row enters the viewport.
            -->
            <ListView x:Name="FileListView"
                      Background="Transparent" BorderThickness="0" Margin="15"
                      AllowDrop="True"
                      Tag="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext}"
                      PreviewMouseLeftButtonDown="FileListView_PreviewMouseLeftButtonDown"
                      PreviewMouseLeftButtonUp="FileListView_PreviewMouseLeftButtonUp"
                      PreviewMouseMove="FileListView_PreviewMouseMove"
                      DragEnter="FileListView_DragEnter"
                      DragOver="FileListView_DragOver"
                      DragLeave="FileListView_DragLeave"
                      Drop="FileListView_Drop"
                      KeyDown="FileListView_KeyDown"
                      GiveFeedback="FileListView_GiveFeedback"
                      SizeChanged="FileListView_SizeChanged"
                      Visibility="{Binding HasFiles, Converter={StaticResource BoolToVisibility}}"
                      ItemsSource="{Binding Items}"
                      ItemContainerStyle="{StaticResource FileRowSlideInStyle}"
                      ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                      VirtualizingPanel.IsVirtualizing="False">

                <ListView.Resources>
                    <Style TargetType="GridViewColumnHeader">
                        <Setter Property="Background"              Value="Transparent"/>
                        <Setter Property="Foreground"              Value="{DynamicResource AppTextTertiaryColor}"/>
                        <Setter Property="FontSize"                Value="11"/>
                        <Setter Property="FontWeight"              Value="SemiBold"/>
                        <Setter Property="Padding"                 Value="8,8,8,6"/>
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        <Setter Property="BorderThickness"         Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="GridViewColumnHeader">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderThickness="0,0,0,1"
                                            BorderBrush="{DynamicResource AppDividerColor}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.Resources>

                <ListView.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="✅  Mark as Trusted (False Positive)"
                                  Command="{Binding PlacementTarget.Tag.MarkAsTrustedCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItem,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  Style="{StaticResource ContextMenuItemStyle}"
                                  FontFamily="Segoe UI" FontSize="13"/>
                        <Separator Background="{DynamicResource AppBorderColor}"/>
                        <MenuItem Header="🚫  Remove Trust"
                                  Command="{Binding PlacementTarget.Tag.RemoveTrustCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItem,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  Style="{StaticResource ContextMenuItemStyle}"
                                  FontFamily="Segoe UI" FontSize="13"/>
                    </ContextMenu>
                </ListView.ContextMenu>

                <ListView.View>
                    <GridView>

                        <!-- Icon + install-order badge — fixed 35px -->
                        <GridViewColumn Header="📄" Width="35"
                                        HeaderContainerStyle="{StaticResource GridViewColumnHeaderStyle}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid Width="24" Height="24" VerticalAlignment="Center"
                                          HorizontalAlignment="Center">
                                        <!-- File type emoji -->
                                        <TextBlock Text="{Binding FileTypeIcon}"
                                                   FontSize="15" FontFamily="Segoe UI Emoji"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource AppTextColor}"/>
                                        <!-- Install order badge — bottom-right, 1-based -->
                                        <Border Width="13" Height="13" CornerRadius="6.5"
                                                Background="{DynamicResource AppPrimaryColor}"
                                                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                Margin="0,0,-2,-2">
                                            <TextBlock Text="{Binding InstallOrder,
                                                               Converter={StaticResource PlusOneConverter}}"
                                                       FontSize="7.5" FontWeight="Bold"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontFamily="Segoe UI"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- File Name — fixed 200px -->
                        <GridViewColumn Header="File Name" Width="200"
                                        HeaderContainerStyle="{StaticResource GridViewColumnHeaderStyle}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FileName}" FontSize="12" FontFamily="Segoe UI"
                                               TextTrimming="CharacterEllipsis" ToolTip="{Binding FilePath}"
                                               Foreground="{DynamicResource AppTextColor}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Size — fixed 75px -->
                        <GridViewColumn Header="Size" Width="75"
                                        HeaderContainerStyle="{StaticResource GridViewColumnHeaderStyle}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Size}" FontSize="11" FontFamily="Consolas"
                                               Foreground="{DynamicResource AppTextSecondaryColor}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Status — fixed 110px -->
                        <GridViewColumn Header="Status" Width="110"
                                        HeaderContainerStyle="{StaticResource GridViewColumnHeaderStyle}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding Status, Converter={StaticResource StatusToBackground}}"
                                            CornerRadius="4" Padding="6,3" HorizontalAlignment="Left"
                                            ToolTip="{Binding TrustTooltip}">
                                        <TextBlock Text="{Binding StatusDisplay}" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="White" FontFamily="Segoe UI"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Custom Args — stretches; width managed in SizeChanged -->
                        <GridViewColumn x:Name="NotesColumn" Header="Custom Args" Width="120"
                                        HeaderContainerStyle="{StaticResource GridViewColumnHeaderStyle}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <TextBlock Text="Override args…"
                                                   FontSize="11" FontFamily="Segoe UI" FontStyle="Italic"
                                                   Foreground="{DynamicResource AppTextTertiaryColor}"
                                                   VerticalAlignment="Center" Margin="5,0,0,0"
                                                   IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CustomArgs}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBox Text="{Binding CustomArgs, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                 Style="{StaticResource NotesTextBoxStyle}"
                                                 MaxLength="120"
                                                 ToolTip="Override auto-detected silent args (e.g. /S /D=C:\MyApp)"
                                                 SpellCheck.IsEnabled="False"/>
                                    </Grid>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Delete — fixed 32px -->
                        <GridViewColumn Header="" Width="32"
                                        HeaderContainerStyle="{StaticResource GridViewColumnHeaderStyle}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource DeleteButtonStyle}"
                                            Command="{Binding RemoveCommand}"
                                            AutomationProperties.Name="Remove file"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
    </Border>
</UserControl>
