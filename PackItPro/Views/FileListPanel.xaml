<!-- Views/FileListPanel.xaml - v5.1
     Fixes vs v5.0:
       - Delete (✕) button now always visible — was clipped at default window width
         because all columns had fixed widths that summed past the panel's 3* share.
       - Notes column stretches to fill all remaining space instead of a fixed 160px.
         SizeChanged in code-behind recalculates: NotesWidth = listViewWidth - 470px
         (470 = 35+200+75+110+32 fixed cols + ~18px scrollbar).
       - HorizontalScrollBarVisibility changed Disabled → Hidden to avoid the WPF
         measure loop that fires on every resize when content sits exactly at boundary.
       - VirtualizingPanel.VirtualizationMode="Recycling" added — reuses row containers
         instead of creating new ones on scroll, eliminating the resize RAM spike.
-->
<UserControl x:Class="PackItPro.Views.FileListPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <Storyboard x:Key="PulseAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="EmptyStateIcon"
                             Storyboard.TargetProperty="Opacity"
                             From="0.4" To="1.0"
                             Duration="0:0:2"
                             AutoReverse="True">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Style x:Key="DeleteButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource AppTextTertiaryColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="ToolTip" Value="Remove"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <Viewbox Width="16" Height="16"
                                     HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Canvas Width="20" Height="20">
                                    <Path Data="{StaticResource Icon.Delete}"
                                          Fill="{TemplateBinding Foreground}"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AppStatusErrorColor}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource AppStatusErrorColor}"/>
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Notes TextBox: invisible at rest, subtle border on hover/focus -->
        <Style x:Key="NotesTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource AppTextSecondaryColor}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="{StaticResource AppPrimaryColor}"/>
            <Setter Property="SelectionBrush" Value="{StaticResource AppPrimaryColor}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Padding="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush"
                                        Value="{StaticResource AppBorderColor}"/>
                                <Setter TargetName="border" Property="Background"
                                        Value="{StaticResource AppPanelHoverColor}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush"
                                        Value="{StaticResource AppPrimaryColor}"/>
                                <Setter TargetName="border" Property="Background"
                                        Value="{StaticResource AppPanelHoverColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border x:Name="MainBorder"
            Margin="0,0,10,0"
            BorderBrush="{StaticResource AppBorderColor}"
            BorderThickness="1" CornerRadius="12"
            Background="{StaticResource AppPanelColor}"
            AllowDrop="True"
            Drop="UserControl_Drop"
            DragEnter="UserControl_DragEnter"
            DragLeave="UserControl_DragLeave">

        <Grid>
            <Border CornerRadius="12" Opacity="0.03">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="White" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- EMPTY STATE -->
            <Grid Name="EmptyDropState"
                  Visibility="{Binding HasFiles, Converter={StaticResource InverseBoolToVisibility}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="30">
                    <Border x:Name="EmptyStateIcon" Width="90" Height="90"
                            Background="{StaticResource AppPanelHoverColor}" CornerRadius="45"
                            HorizontalAlignment="Center" Margin="0,0,0,20">
                        <TextBlock Text="📦" FontSize="48"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{StaticResource AppPrimaryColor}"
                                   FontFamily="Segoe UI Emoji"/>
                    </Border>

                    <TextBlock Text="Drop Your Files Here" FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource AppTextColor}"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               FontFamily="Segoe UI" Margin="0,0,0,6"/>

                    <TextBlock FontSize="13" Foreground="{StaticResource AppTextTertiaryColor}"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               LineHeight="20" FontFamily="Segoe UI" Margin="0,0,0,18">
                        <Run Text="Drag and drop files or folders here"/>
                        <LineBreak/>
                        <Run FontSize="11">
                            <Run.Text>
                                <MultiBinding StringFormat="Maximum {0} files per package">
                                    <Binding RelativeSource="{RelativeSource AncestorType=Window}"
                                             Path="DataContext.Settings.SettingsModel.MaxFilesInList"/>
                                </MultiBinding>
                            </Run.Text>
                        </Run>
                    </TextBlock>

                    <Button Content="Browse Files"
                            Style="{StaticResource Win11Button}"
                            Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.BrowseFilesCommand}"
                            Height="40" Padding="24,0" FontSize="14" FontWeight="SemiBold" Cursor="Hand"/>
                </StackPanel>
            </Grid>

            <!-- FILE LIST -->
            <ListView x:Name="FileListView"
                      Background="Transparent" BorderThickness="0" Margin="15"
                      AllowDrop="True"
                      Tag="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext}"
                      PreviewMouseLeftButtonDown="FileListView_PreviewMouseLeftButtonDown"
                      PreviewMouseLeftButtonUp="FileListView_PreviewMouseLeftButtonUp"
                      PreviewMouseMove="FileListView_PreviewMouseMove"
                      DragEnter="FileListView_DragEnter"
                      DragLeave="FileListView_DragLeave"
                      Drop="FileListView_Drop"
                      SizeChanged="FileListView_SizeChanged"
                      Visibility="{Binding HasFiles, Converter={StaticResource BoolToVisibility}}"
                      ItemsSource="{Binding Items}"
                      ItemContainerStyle="{StaticResource FileItemStyle}"
                      ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling">

                <ListView.Resources>
                    <Style TargetType="GridViewColumnHeader">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{StaticResource AppTextTertiaryColor}"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="8,8,8,6"/>
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="GridViewColumnHeader">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderThickness="0,0,0,1"
                                            BorderBrush="{StaticResource AppDividerColor}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.Resources>

                <ListView.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="✅  Mark as Trusted (False Positive)"
                                  Command="{Binding PlacementTarget.Tag.MarkAsTrustedCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItem,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  Style="{StaticResource ContextMenuItemStyle}"
                                  FontFamily="Segoe UI" FontSize="13"/>
                        <Separator Background="{StaticResource AppBorderColor}"/>
                        <MenuItem Header="🚫  Remove Trust"
                                  Command="{Binding PlacementTarget.Tag.RemoveTrustCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItem,
                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  Style="{StaticResource ContextMenuItemStyle}"
                                  FontFamily="Segoe UI" FontSize="13"/>
                    </ContextMenu>
                </ListView.ContextMenu>

                <ListView.View>
                    <GridView>

                        <!-- Icon — fixed 35px -->
                        <GridViewColumn Header="📄" Width="35"
                                        HeaderContainerStyle="{StaticResource GridViewColumnHeaderStyle}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FileTypeIcon}"
                                               FontSize="16" FontFamily="Segoe UI Emoji"
                                               HorizontalAlignment="Center"
                                               Foreground="{StaticResource AppTextColor}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- File Name — fixed 200px -->
                        <GridViewColumn Header="File Name" Width="200"
                                        HeaderContainerStyle="{StaticResource GridViewColumnHeaderStyle}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FileName}" FontSize="12" FontFamily="Segoe UI"
                                               TextTrimming="CharacterEllipsis" ToolTip="{Binding FilePath}"
                                               Foreground="{StaticResource AppTextColor}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Size — fixed 75px -->
                        <GridViewColumn Header="Size" Width="75"
                                        HeaderContainerStyle="{StaticResource GridViewColumnHeaderStyle}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Size}" FontSize="11" FontFamily="Consolas"
                                               Foreground="{StaticResource AppTextSecondaryColor}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Status — fixed 110px -->
                        <GridViewColumn Header="Status" Width="110"
                                        HeaderContainerStyle="{StaticResource GridViewColumnHeaderStyle}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding Status, Converter={StaticResource StatusToBackground}}"
                                            CornerRadius="4" Padding="6,3" HorizontalAlignment="Left"
                                            ToolTip="{Binding TrustTooltip}">
                                        <TextBlock Text="{Binding StatusDisplay}" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AppTextColor}" FontFamily="Segoe UI"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Notes — stretches to fill remaining space; width managed in SizeChanged -->
                        <GridViewColumn x:Name="NotesColumn" Header="Notes" Width="120"
                                        HeaderContainerStyle="{StaticResource GridViewColumnHeaderStyle}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <!-- Placeholder shown when Notes is empty -->
                                        <TextBlock Text="Add a note…"
                                                   FontSize="11" FontFamily="Segoe UI" FontStyle="Italic"
                                                   Foreground="{StaticResource AppTextTertiaryColor}"
                                                   VerticalAlignment="Center" Margin="5,0,0,0"
                                                   IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Notes}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBox Text="{Binding Notes, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                 Style="{StaticResource NotesTextBoxStyle}"
                                                 MaxLength="120"
                                                 ToolTip="{Binding Notes}"
                                                 SpellCheck.IsEnabled="False"/>
                                    </Grid>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Delete — fixed 32px, always last so it's never clipped -->
                        <GridViewColumn Header="" Width="32"
                                        HeaderContainerStyle="{StaticResource GridViewColumnHeaderStyle}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource DeleteButtonStyle}"
                                            Command="{Binding RemoveCommand}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
    </Border>
</UserControl>
