<Window x:Class="PackItPro.Views.PackItProSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PackItPro Settings"
        Height="680" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource AppBackgroundColor}"
        ShowInTaskbar="False">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource AppPanelColor}"
                BorderBrush="{StaticResource AppBorderColor}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="22,18">

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- Header -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                        <TextBlock Text="⚙️" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Advanced Settings"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource AppTextColor}"
                                   FontFamily="Segoe UI"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- ── Output ───────────────────────────── -->
                    <TextBlock Text="OUTPUT"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource AppTextTertiaryColor}"
                               FontFamily="Segoe UI"
                               Margin="0,0,0,8"
                              />

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Output location"
                                   FontSize="13" Foreground="{StaticResource AppTextSecondaryColor}"
                                   FontFamily="Segoe UI" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="OutputLocationBox"
                                 Height="32" FontFamily="Segoe UI" FontSize="12"
                                 Padding="10,4" VerticalContentAlignment="Center"
                                 IsReadOnly="True" Opacity="0.7"
                                 ToolTip="Change via Settings → Output Location"/>
                    </Grid>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Default file name"
                                   FontSize="13" Foreground="{StaticResource AppTextSecondaryColor}"
                                   FontFamily="Segoe UI" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="OutputFileNameBox"
                                 Height="32" FontFamily="Segoe UI" FontSize="12"
                                 Padding="10,4" VerticalContentAlignment="Center"/>
                    </Grid>

                    <!-- Divider -->
                    <Border Height="1" Background="{StaticResource AppDividerColor}" Margin="0,12,0,12"/>

                    <!-- ── Security ─────────────────────────── -->
                    <TextBlock Text="SECURITY"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource AppTextTertiaryColor}"
                               FontFamily="Segoe UI"
                               Margin="0,0,0,8"
                              />

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Min detections to flag"
                                   FontSize="13" Foreground="{StaticResource AppTextSecondaryColor}"
                                   FontFamily="Segoe UI" VerticalAlignment="Center"
                                   ToolTip="Number of VirusTotal engines that must flag a file before it's marked Infected"/>
                        <TextBox Grid.Column="1" x:Name="MinDetectionsBox"
                                 Height="32" FontFamily="Consolas" FontSize="12"
                                 Padding="10,4" VerticalContentAlignment="Center"/>
                    </Grid>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Verify integrity"
                                   FontSize="13" Foreground="{StaticResource AppTextSecondaryColor}"
                                   FontFamily="Segoe UI" VerticalAlignment="Center"
                                   ToolTip="Re-hash files after packaging to verify the output is intact"/>
                        <CheckBox Grid.Column="1" x:Name="VerifyIntegrityBox"
                                  VerticalAlignment="Center" Margin="2,0,0,0"/>
                    </Grid>

                    <!-- Divider -->
                    <Border Height="1" Background="{StaticResource AppDividerColor}" Margin="0,12,0,12"/>

                    <!-- ── Package ──────────────────────────── -->
                    <TextBlock Text="PACKAGE"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource AppTextTertiaryColor}"
                               FontFamily="Segoe UI"
                               Margin="0,0,0,8"
                              />

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Max files in list"
                                   FontSize="13" Foreground="{StaticResource AppTextSecondaryColor}"
                                   FontFamily="Segoe UI" VerticalAlignment="Center"
                                   ToolTip="Maximum number of files that can be added to a single package (1–50)"/>
                        <TextBox Grid.Column="1" x:Name="MaxFilesBox"
                                 Height="32" FontFamily="Consolas" FontSize="12"
                                 Padding="10,4" VerticalContentAlignment="Center"/>
                    </Grid>

                    <!-- Divider -->
                    <Border Height="1" Background="{StaticResource AppDividerColor}" Margin="0,12,0,12"/>

                    <!-- ── Trusted Hashes ───────────────────────── -->
                    <TextBlock Text="TRUSTED FALSE POSITIVES"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource AppTextTertiaryColor}"
                               FontFamily="Segoe UI"
                               Margin="0,0,0,8"/>

                    <!-- Empty state -->
                    <TextBlock x:Name="NoTrustedText"
                               Text="No trusted hashes — files marked as false positives will appear here."
                               FontSize="12" FontFamily="Segoe UI"
                               Foreground="{StaticResource AppTextTertiaryColor}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8"
                               Visibility="Visible"/>

                    <!-- List -->
                    <ListView x:Name="TrustedHashList"
                              MaxHeight="160"
                              Visibility="Collapsed"
                              Background="{StaticResource AppCardColor}"
                              BorderBrush="{StaticResource AppBorderColor}"
                              BorderThickness="1"
                              Margin="0,0,0,8"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,7"
                                        BorderBrush="{StaticResource AppDividerColor}"
                                        BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding FileName}"
                                                       FontSize="12" FontFamily="Segoe UI"
                                                       Foreground="{StaticResource AppTextColor}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock FontSize="10" FontFamily="Consolas"
                                                       Foreground="{StaticResource AppTextTertiaryColor}"
                                                       Margin="0,2,0,0">
                                                <Run Text="{Binding ShortHash}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{Binding TrustedAtFormatted}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="Remove"
                                                Height="26" Padding="10,0"
                                                FontSize="11" FontFamily="Segoe UI"
                                                VerticalAlignment="Center"
                                                Tag="{Binding Hash}"
                                                Click="RemoveTrust_Click"
                                                Foreground="{StaticResource AppStatusErrorColor}"
                                                Background="Transparent"
                                                BorderBrush="{StaticResource AppStatusErrorColor}"
                                                BorderThickness="1"
                                                Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="5">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#2a1010"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Divider -->
                    <Border Background="{StaticResource AppCardColor}"
                            CornerRadius="6" Padding="12" BorderThickness="1"
                            BorderBrush="{StaticResource AppBorderColor}">
                        <StackPanel>
                            <TextBlock Text="Settings file location"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource AppTextTertiaryColor}"
                                       FontFamily="Segoe UI" Margin="0,0,0,4"/>
                            <TextBlock x:Name="SettingsPathText"
                                       FontSize="11" FontFamily="Consolas"
                                       Foreground="{StaticResource AppTextSecondaryColor}"
                                       TextWrapping="Wrap"/>
                            <Button Content="Open in Notepad"
                                    Height="28" HorizontalAlignment="Left"
                                    Margin="0,8,0,0" Padding="12,0"
                                    FontSize="12"
                                    Click="OpenInNotepad_Click"
                                    Style="{StaticResource Win11Button}"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Save / Cancel -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="Cancel"
                    Width="90" Height="34"
                    Margin="0,0,10,0"
                    Click="CancelButton_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="{StaticResource AppPanelHoverColor}"/>
                        <Setter Property="Foreground" Value="{StaticResource AppTextColor}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource AppBorderColor}"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="FontFamily" Value="Segoe UI"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="7">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AppBorderColor}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="Save"
                    Width="90" Height="34"
                    Click="SaveButton_Click"
                    IsDefault="True"
                    Style="{StaticResource Win11Button}"/>
        </StackPanel>
    </Grid>
</Window>
