<Window x:Class="PackItPro.Views.ScanResultsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Scan Results"
        Height="Auto" Width="460"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource AppBackgroundColor}"
        ShowInTaskbar="False">

    <Grid Margin="12">
        <Border Background="{StaticResource AppPanelColor}"
                BorderBrush="{StaticResource AppBorderColor}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="24,20">
            <StackPanel>

                <!-- Header -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                    <Border x:Name="IconBorder"
                            Width="40" Height="40" CornerRadius="20"
                            Background="#3322c55e"
                            Margin="0,0,14,0" VerticalAlignment="Center">
                        <TextBlock x:Name="IconText" Text="🛡️"
                                   FontSize="20"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="TitleText"
                                   Text="Scan Complete"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource AppTextColor}"
                                   FontFamily="Segoe UI"/>
                        <TextBlock x:Name="SubtitleText"
                                   Text=""
                                   FontSize="12"
                                   Foreground="{StaticResource AppTextTertiaryColor}"
                                   FontFamily="Segoe UI"/>
                    </StackPanel>
                </StackPanel>

                <!-- Stats row -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{StaticResource AppCardColor}"
                            CornerRadius="8" Padding="10,8"
                            BorderBrush="{StaticResource AppBorderColor}" BorderThickness="1">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="TotalText" Text="0"
                                       FontSize="20" FontWeight="Bold" FontFamily="Consolas"
                                       Foreground="{StaticResource AppTextColor}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Scanned"
                                       FontSize="10" Foreground="{StaticResource AppTextTertiaryColor}"
                                       FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="{StaticResource AppCardColor}"
                            CornerRadius="8" Padding="10,8"
                            BorderBrush="{StaticResource AppBorderColor}" BorderThickness="1">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="CleanText" Text="0"
                                       FontSize="20" FontWeight="Bold" FontFamily="Consolas"
                                       Foreground="{StaticResource AppStatusCleanColor}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Clean"
                                       FontSize="10" Foreground="{StaticResource AppTextTertiaryColor}"
                                       FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4" Background="{StaticResource AppCardColor}"
                            CornerRadius="8" Padding="10,8"
                            BorderBrush="{StaticResource AppBorderColor}" BorderThickness="1">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock x:Name="IssueText" Text="0"
                                       FontSize="20" FontWeight="Bold" FontFamily="Consolas"
                                       Foreground="{StaticResource AppStatusErrorColor}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="IssueLabel" Text="Infected"
                                       FontSize="10" Foreground="{StaticResource AppTextTertiaryColor}"
                                       FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Detail message -->
                <Border x:Name="DetailBox"
                        Background="{StaticResource AppCardColor}"
                        CornerRadius="6" Padding="12"
                        BorderBrush="{StaticResource AppBorderColor}"
                        BorderThickness="1"
                        Margin="0,0,0,20"
                        Visibility="Collapsed">
                    <TextBlock x:Name="DetailText"
                               FontSize="12"
                               Foreground="{StaticResource AppTextSecondaryColor}"
                               FontFamily="Segoe UI"
                               TextWrapping="Wrap"
                               LineHeight="18"/>
                </Border>

                <!-- OK -->
                <Button Content="OK"
                        Width="90" Height="34"
                        HorizontalAlignment="Right"
                        IsDefault="True"
                        Click="OkButton_Click"
                        Style="{StaticResource Win11Button}"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>
