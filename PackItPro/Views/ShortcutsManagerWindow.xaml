<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="PackItPro.Views.ShortcutsManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:vm="clr-namespace:PackItPro.ViewModels"
        mc:Ignorable="d"
        Title="Manage Shortcuts"
        Height="600" Width="900"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinHeight="400" MinWidth="700"
        Background="{DynamicResource AppBackgroundColor}"
        UseLayoutRounding="True">

    <!-- ?? Keyboard shortcuts ???????????????????????????????????????????????? -->
    <Window.InputBindings>
        <KeyBinding Key="A" Modifiers="Alt" Command="{Binding AddShortcutCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding CloseCommand}"/>
    </Window.InputBindings>

    <Grid Margin="20" Background="{DynamicResource AppBackgroundColor}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ?? Header ????????????????????????????????????????????????????????? -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="?? Shortcuts"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource AppTextColor}"
                       FontFamily="Segoe UI"
                       VerticalAlignment="Center"
                       Margin="0,0,16,0"/>

            <TextBlock Grid.Column="1"
                       Text="Create Windows shortcuts to be installed after packaging."
                       FontSize="13"
                       Foreground="{DynamicResource AppTextTertiaryColor}"
                       FontFamily="Segoe UI"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"/>

            <Button Grid.Column="2"
                    Command="{Binding AddShortcutCommand}"
                    Height="32" Padding="16,0"
                    Style="{StaticResource Win11Button}"
                    ToolTip="Add a new shortcut (Alt+A)">
                <TextBlock>
                    <Run Text="+ "/>
                    <Run Text="A" TextDecorations="Underline"/>
                    <Run Text="dd"/>
                </TextBlock>
            </Button>
        </Grid>

        <!-- ?? Divider ????????????????????????????????????????????????????????? -->
        <Border Grid.Row="0" Height="1" Background="{DynamicResource AppDividerColor}"
                VerticalAlignment="Bottom" Margin="0,0,0,-10"/>

        <!-- ?? Content ????????????????????????????????????????????????????????? -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <!-- Empty state -->
                <TextBlock Text="No shortcuts defined. Click '+ Add' to create one or press Alt+A."
                           Foreground="{DynamicResource AppTextTertiaryColor}"
                           FontSize="13"
                           FontFamily="Segoe UI"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           Margin="20,40,20,40">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasShortcuts}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Shortcut list -->
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ShortcutViewModel}">
                            <Border Background="{DynamicResource AppCardColor}"
                                    BorderBrush="{DynamicResource AppBorderColor}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16"
                                    Margin="0,0,0,12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Row 0: Name, Location, Remove -->
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="36"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBox Grid.Column="0"
                                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                 Height="36" Padding="10,6"
                                                 VerticalContentAlignment="Center"
                                                 FontFamily="Segoe UI" FontSize="13"
                                                 ToolTip="Shortcut name shown on Desktop / Start Menu (required)">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AppBorderColor}"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsFocused" Value="True">
                                                            <Setter Property="BorderBrush" Value="{DynamicResource AppPrimaryColor}"/>
                                                            <Setter Property="BorderThickness" Value="2"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>

                                        <TextBlock Grid.Column="1" Margin="6,0,0,0"
                                                   Text="*"
                                                   Foreground="{DynamicResource AppStatusErrorColor}"
                                                   VerticalAlignment="Center"
                                                   FontWeight="Bold"
                                                   ToolTip="Required field"/>

                                        <ComboBox Grid.Column="3"
                                                  SelectedItem="{Binding Location, Mode=TwoWay}"
                                                  Height="36"
                                                  Style="{StaticResource ComprehensiveComboBoxStyle}"
                                                  VerticalContentAlignment="Center"
                                                  FontFamily="Segoe UI" FontSize="12"
                                                  ToolTip="Where the shortcut will be placed">
                                            <ComboBox.ItemContainerStyle>
                                                <Style TargetType="ComboBoxItem">
                                                    <Setter Property="Foreground" Value="{DynamicResource AppTextColor}"/>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="Padding" Value="10,6"/>
                                                    <Setter Property="FontFamily" Value="Segoe UI"/>
                                                    <Setter Property="FontSize" Value="12"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#2d2d44"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource AppPrimaryColor}"/>
                                                            <Setter Property="Foreground" Value="#f1f5f9"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ComboBox.ItemContainerStyle>
                                            <ComboBoxItem Content="??  Desktop"/>
                                            <ComboBoxItem Content="??  Start Menu"/>
                                            <ComboBoxItem Content="??  Startup"/>
                                        </ComboBox>

                                        <Button Grid.Column="5"
                                                Content="?"
                                                Command="{Binding RemoveCommand}"
                                                Width="36" Height="36"
                                                FontSize="12"
                                                ToolTip="Remove this shortcut"
                                                Cursor="Hand">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource AppTextTertiaryColor}"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}" 
                                                                        CornerRadius="6"
                                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                                        BorderThickness="{TemplateBinding BorderThickness}">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#3a1a1a"/>
                                                            <Setter Property="Foreground" Value="#ef4444"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>

                                    <!-- Row 2: Target Path -->
                                    <TextBox Grid.Row="2"
                                             Text="{Binding TargetPath, UpdateSourceTrigger=PropertyChanged}"
                                             Height="36" Padding="10,6"
                                             VerticalContentAlignment="Center"
                                             FontFamily="Consolas" FontSize="12"
                                             ToolTip="Full path to the target exe. Supports environment variables like %ProgramFiles%.">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource AppBorderColor}"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsFocused" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AppPrimaryColor}"/>
                                                        <Setter Property="BorderThickness" Value="2"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>

                                    <!-- Row 4: Arguments -->
                                    <TextBox Grid.Row="4"
                                             Text="{Binding Arguments, UpdateSourceTrigger=PropertyChanged}"
                                             Height="36" Padding="10,6"
                                             VerticalContentAlignment="Center"
                                             FontFamily="Consolas" FontSize="12"
                                             ToolTip="Optional: command-line arguments passed to the target.">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource AppBorderColor}"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsFocused" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AppPrimaryColor}"/>
                                                        <Setter Property="BorderThickness" Value="2"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>

                                    <!-- Row 6: Description -->
                                    <TextBox Grid.Row="6"
                                             Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                             Height="36" Padding="10,6"
                                             VerticalContentAlignment="Center"
                                             FontFamily="Consolas" FontSize="12"
                                             ToolTip="Optional: description shown in the shortcut properties.">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource AppBorderColor}"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsFocused" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AppPrimaryColor}"/>
                                                        <Setter Property="BorderThickness" Value="2"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- ?? Footer buttons ????????????????????????????????????????????????? -->
        <Border Grid.Row="2" Height="1" Background="{DynamicResource AppDividerColor}"
                Margin="0,10,0,16"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Changes are saved automatically."
                       FontSize="11"
                       Foreground="{DynamicResource AppTextTertiaryColor}"
                       VerticalAlignment="Center"
                       FontFamily="Segoe UI"/>

            <Button Grid.Column="1"
                    Content="Close"
                    Command="{Binding CloseCommand}"
                    Height="36" Padding="20,0"
                    Style="{StaticResource Win11Button}"
                    IsDefault="True"/>
        </Grid>
    </Grid>
</Window>
