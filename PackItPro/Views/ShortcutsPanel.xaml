<!-- PackItPro/Views/ShortcutsPanel.xaml -->
<UserControl x:Class="PackItPro.Views.ShortcutsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:PackItPro.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="320" d:DesignWidth="400">

    <Border Background="{StaticResource AppPanelColor}"
            CornerRadius="12"
            Padding="20"
            Margin="0,0,0,15"
            BorderBrush="{StaticResource AppBorderColor}"
            BorderThickness="1">

        <StackPanel>

    <!-- Header ──────────────────────────────────────────────────── -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="🔗"
                           FontSize="18"
                           Margin="0,0,8,0"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Shortcuts"
                               FontSize="16"
                               Foreground="{StaticResource AppTextColor}"
                               FontWeight="SemiBold"
                               FontFamily="Segoe UI">
                        <TextBlock.ToolTip>
                            <ToolTip MaxWidth="300">
                                <TextBlock TextWrapping="Wrap">
                                    <Run Text="Create Windows shortcuts to be installed after packaging."/>
                                    <LineBreak/><LineBreak/>
                                    <Run Text="Keyboard shortcuts:"/>
                                    <LineBreak/>
                                    <Run Text="• Alt+A: Add shortcut"/>
                                    <LineBreak/>
                                    <Run Text="• Tab: Navigate between fields"/>
                                    <LineBreak/>
                                    <Run Text="• Shift+Tab: Navigate backward"/>
                                    <LineBreak/>
                                    <Run Text="• Enter: Confirm delete (with warning)"/>
                                </TextBlock>
                            </ToolTip>
                        </TextBlock.ToolTip>
                    </TextBlock>
                    <TextBlock Text="Created on the end-user's machine after installation"
                               FontSize="11"
                               FontFamily="Segoe UI"
                               Foreground="{StaticResource AppTextTertiaryColor}"
                               Margin="0,1,0,0"/>
                </StackPanel>

                <Button Grid.Column="2"
                        x:Name="AddShortcutButton"
                        Command="{Binding AddShortcutCommand}"
                        Height="30" Padding="12,0"
                        Style="{StaticResource Win11Button}"
                        AutomationProperties.Name="Add shortcut"
                        AutomationProperties.AcceleratorKey="Alt+A"
                        ToolTip="Add a shortcut to be created after installation completes (Alt+A)">
                    <TextBlock>
                        <Run Text="+ "/>
                        <Run Text="A" TextDecorations="Underline"/>
                        <Run Text="dd"/>
                    </TextBlock>
                </Button>
            </Grid>

            <!-- Divider ─────────────────────────────────────────────────── -->
            <Border Height="1"
                    Background="{StaticResource AppDividerColor}"
                    Margin="0,0,0,12"/>

            <!-- Empty state hint ─────────────────────────────────────────── -->
            <TextBlock Text="No shortcuts defined. Click '+ Add' to create one or press Alt+A."
                       Foreground="{StaticResource AppTextTertiaryColor}"
                       FontSize="12"
                       FontFamily="Segoe UI"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,8">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasShortcuts}" Value="False">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Shortcut rows ────────────────────────────────────────────── -->
            <ItemsControl ItemsSource="{Binding Items}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ShortcutViewModel}">
                        <Border Background="{StaticResource AppCardColor}"
                                BorderBrush="{StaticResource AppBorderColor}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <!-- Name + Location + Remove -->
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/>
                                    <!-- Target path -->
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/>
                                    <!-- Arguments -->
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/>
                                    <!-- Description -->
                                </Grid.RowDefinitions>

                                <!-- Row 0: Name + Location + Remove ──────────── -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="32"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBox Grid.Column="0"
                                             x:Name="ShortcutNameBox"
                                             Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                             Height="32" Padding="8,4"
                                             VerticalContentAlignment="Center"
                                             FontFamily="Segoe UI" FontSize="13"
                                             AutomationProperties.Name="Shortcut name"
                                             AutomationProperties.HelpText="Display name shown on Desktop or Start Menu (required)"
                                             ToolTip="Shortcut name shown on Desktop / Start Menu (required)">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource AppBorderColor}"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsFocused" Value="True">
                                                        <Setter Property="BorderBrush" Value="{StaticResource AppPrimaryColor}"/>
                                                        <Setter Property="BorderThickness" Value="2"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>

                                    <!-- Required indicator for Name -->
                                    <TextBlock Grid.Column="1" Margin="4,0,0,0"
                                               Text="*"
                                               Foreground="{StaticResource AppErrorColor}"
                                               VerticalAlignment="Center"
                                               FontWeight="Bold"
                                               ToolTip="Required field"/>

                                    <!-- Location ComboBox -->
                                    <ComboBox Grid.Column="3"
                                              x:Name="ShortcutLocationBox"
                                              SelectedItem="{Binding Location, Mode=TwoWay}"
                                              Height="32"
                                              Style="{StaticResource ComprehensiveComboBoxStyle}"
                                              VerticalContentAlignment="Center"
                                              FontFamily="Segoe UI" FontSize="12"
                                              AutomationProperties.Name="Shortcut location"
                                              AutomationProperties.HelpText="Where the shortcut will be placed: Desktop, Start Menu, or Startup"
                                              ToolTip="Where the shortcut will be placed">
                                        <ComboBox.ItemContainerStyle>
                                            <Style TargetType="ComboBoxItem">
                                                <Setter Property="Foreground" Value="{StaticResource AppTextColor}"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Padding" Value="10,5"/>
                                                <Setter Property="FontFamily" Value="Segoe UI"/>
                                                <Setter Property="FontSize" Value="12"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#2d2d44"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource AppPrimaryColor}"/>
                                                        <Setter Property="Foreground" Value="#f1f5f9"/>
                                                    </Trigger>
                                                    <Trigger Property="IsFocused" Value="True">
                                                        <Setter Property="BorderBrush" Value="{StaticResource AppPrimaryColor}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ComboBox.ItemContainerStyle>
                                        <ComboBoxItem Content="🖥  Desktop"    ToolTip="Places the shortcut on the current user's Desktop"/>
                                        <ComboBoxItem Content="📋  Start Menu" ToolTip="Places the shortcut in the Start Menu Programs folder"/>
                                        <ComboBoxItem Content="🚀  Startup"    ToolTip="Runs the target automatically on Windows logon"/>
                                    </ComboBox>

                                    <!-- Remove button -->
                                    <Button Grid.Column="5"
                                            x:Name="RemoveShortcutButton"
                                            Content="✕"
                                            Command="{Binding RemoveCommand}"
                                            Width="32" Height="32"
                                            FontSize="11"
                                            AutomationProperties.Name="Remove shortcut"
                                            AutomationProperties.HelpText="Delete this shortcut row from the list"
                                            ToolTip="Remove this shortcut"
                                            Cursor="Hand">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="{StaticResource AppTextTertiaryColor}"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" 
                                                                    CornerRadius="6"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#3a1a1a"/>
                                                        <Setter Property="Foreground" Value="#ef4444"/>
                                                    </Trigger>
                                                    <Trigger Property="IsFocused" Value="True">
                                                        <Setter Property="BorderBrush" Value="{StaticResource AppPrimaryColor}"/>
                                                        <Setter Property="BorderThickness" Value="2"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>

                                <!-- Row 2: Target path ───────────────────── -->
                                <TextBox Grid.Row="2"
                                         x:Name="TargetPathBox"
                                         Text="{Binding TargetPath, UpdateSourceTrigger=PropertyChanged}"
                                         Height="32" Padding="8,4"
                                         VerticalContentAlignment="Center"
                                         FontFamily="Consolas" FontSize="12"
                                         AutomationProperties.Name="Target path"
                                         AutomationProperties.HelpText="Full path to the target executable. Supports environment variables like %ProgramFiles% (required)"
                                         ToolTip="Full path to the target exe. Supports environment variables like %ProgramFiles%.">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource AppBorderColor}"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsFocused" Value="True">
                                                    <Setter Property="BorderBrush" Value="{StaticResource AppPrimaryColor}"/>
                                                    <Setter Property="BorderThickness" Value="2"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>

                                <!-- Row 4: Arguments ─────────────────────── -->
                                <TextBox Grid.Row="4"
                                         x:Name="ArgumentsBox"
                                         Text="{Binding Arguments, UpdateSourceTrigger=PropertyChanged}"
                                         Height="32" Padding="8,4"
                                         VerticalContentAlignment="Center"
                                         FontFamily="Consolas" FontSize="12"
                                         AutomationProperties.Name="Command-line arguments"
                                         AutomationProperties.HelpText="Optional arguments passed to the target executable (leave blank for none)"
                                         ToolTip="Optional: command-line arguments passed to the target (leave blank for none)">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource AppBorderColor}"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsFocused" Value="True">
                                                    <Setter Property="BorderBrush" Value="{StaticResource AppPrimaryColor}"/>
                                                    <Setter Property="BorderThickness" Value="2"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>

                                <!-- Row 6: Description -->
                                <TextBox Grid.Row="6"
                                         x:Name="DescriptionBox"
                                         Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                         Height="32" Padding="8,4"
                                         VerticalContentAlignment="Center"
                                         FontFamily="Consolas" FontSize="12"
                                         AutomationProperties.Name="Description"
                                         AutomationProperties.HelpText="Optional tooltip shown in the shortcut Properties dialog (leave blank for none)"
                                         ToolTip="Optional: description shown in the shortcut's Properties dialog (leave blank for none)">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource AppBorderColor}"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsFocused" Value="True">
                                                    <Setter Property="BorderBrush" Value="{StaticResource AppPrimaryColor}"/>
                                                    <Setter Property="BorderThickness" Value="2"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </Border>
</UserControl>
